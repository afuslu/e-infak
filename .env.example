# Root .env.example

# Database
DATABASE_URL=postgresql+asyncpg://einfak:einfak123@localhost:5432/einfak

# Redis
REDIS_URL=redis://localhost:6379/0

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_VERSION=v1

# JWT
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@e-infak.org
FROM_NAME=E-İnfak

# VPOS (Vakıf Katılım)
VPOS_MERCHANT_ID=
VPOS_TERMINAL_ID=
VPOS_PASSWORD=
VPOS_TEST_MODE=true

# SMS (Netgsm) - Optional
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_SENDER=EINFAK

# File Storage (S3/R2) - Optional
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=e-infak-files
S3_REGION=auto

# Monitoring - Optional
SENTRY_DSN=
