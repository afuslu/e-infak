# Application
APP_NAME="E-İnfak API"
APP_VERSION="2.0.0"
ENVIRONMENT="development"
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://einfak:einfak123@localhost:5432/einfak
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@e-infak.org
FROM_NAME="E-İnfak"

# File Storage (S3 or R2)
S3_ENDPOINT_URL=https://your-endpoint.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=e-infak-files
S3_REGION=auto

# VPOS (Vakıf Katılım)
VPOS_MERCHANT_ID=your-merchant-id
VPOS_TERMINAL_ID=your-terminal-id
VPOS_PASSWORD=your-password
VPOS_TEST_MODE=true

# SMS (Netgsm)
NETGSM_USERNAME=your-username
NETGSM_PASSWORD=your-password
NETGSM_SENDER=EINFAK

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Monitoring
SENTRY_DSN=your-sentry-dsn
